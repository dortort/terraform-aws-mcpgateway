@startuml terraform-aws-mcpgateway-architecture

top to bottom direction
skinparam defaultTextAlignment center
skinparam shadowing false
skinparam backgroundColor #FEFEFE
skinparam rectangle {
    RoundCorner 8
}

title terraform-aws-mcpgateway Architecture

' === Internet ===
cloud "Internet" as internet #F5F5F5 {
    rectangle "Client / API Consumer" as client #FFFFFF
}

' === Edge ===
package "Edge" as edge #E3F2FD {
    rectangle "Route 53 (DNS)" as route53 #BBDEFB
    rectangle "ACM Certificate (TLS)" as acm #BBDEFB
    rectangle "AWS WAF\n(managed rules + rate limiting)" as waf #EF9A9A
}

' === VPC ===
rectangle "VPC (10.0.0.0/16)" as vpc #F5F5F5 {

    package "Public Subnets" as pub_subnets #E3F2FD {
        rectangle "Application Load Balancer\n(HTTPS:443 -> HTTP:4444)" as alb #90CAF9
        rectangle "NAT Gateway" as natgw #90CAF9
    }

    package "Private Subnets" as priv_subnets #F1F8E9 {

        rectangle "Compute (orchestrator x compute_type -- pick one)" as compute #E8F5E9 {
            rectangle "ECS Fargate" as ecs_fargate #C8E6C9
            rectangle "ECS on EC2" as ecs_ec2 #C8E6C9
            rectangle "EKS Fargate" as eks_fargate #C8E6C9
            rectangle "EKS on EC2" as eks_ec2 #C8E6C9
        }

        package "Data Layer" as data #FFF3E0 {
            database "Aurora PostgreSQL\nor RDS MySQL" as db #FFE0B2
            database "ElastiCache Redis\n(optional)" as redis #FFE0B2
        }
    }

    package "Supporting Services" as support #F3E5F5 {
        rectangle "Secrets Manager" as secrets #E1BEE7
        rectangle "KMS" as kms #E1BEE7
        rectangle "IAM Roles" as iam #E1BEE7
        rectangle "CloudWatch\n(logs / metrics)" as cw #E1BEE7
        rectangle "S3 (OPA bundles)" as s3 #E1BEE7
    }
}

' === Layout hints (hidden) ===
route53 -[hidden]down-> acm
acm -[hidden]down-> waf
alb -[hidden]right-> natgw
ecs_fargate -[hidden]right-> ecs_ec2
eks_fargate -[hidden]right-> eks_ec2
ecs_fargate -[hidden]down-> eks_fargate
ecs_ec2 -[hidden]down-> eks_ec2
db -[hidden]right-> redis
secrets -[hidden]right-> kms
kms -[hidden]right-> iam
iam -[hidden]right-> cw
cw -[hidden]right-> s3

' === Primary request flow ===
client -[#1565C0,bold]-> route53 : DNS
route53 -[#1565C0,bold]-> acm
acm -[#1565C0,bold]-> waf : HTTPS
waf -[#1565C0,bold]-> alb
alb -[#2E7D32,bold]-> compute : HTTP 4444

' === Compute to Data ===
compute -[#E65100,bold]-> db : SQL
compute -[#E65100]-> redis : cache

' === Supporting connections ===
secrets .[#7B1FA2]-> compute : inject secrets
s3 .[#7B1FA2]-> compute : OPA policies
compute .[#9E9E9E]-> cw : logs
compute .[#9E9E9E]-> natgw : outbound

' === KMS encryption ===
kms .[#7B1FA2]-> db : encrypt
kms .[#7B1FA2]-> redis
kms .[#7B1FA2]-> secrets

' === Legend ===
legend right
  |<#90CAF9>  | Network (ALB, NAT, DNS) |
  |<#C8E6C9>  | Compute (ECS / EKS) |
  |<#FFE0B2>  | Data (DB, Redis) |
  |<#EF9A9A>  | Security (WAF) |
  |<#E1BEE7>  | Supporting (Secrets, KMS, IAM, CW, S3) |
  Bold arrows: primary request path
  Dotted: supporting & monitoring
end legend

@enduml
